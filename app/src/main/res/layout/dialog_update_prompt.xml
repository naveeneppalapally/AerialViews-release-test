<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/update_prompt_panel_background"
    android:orientation="vertical"
    android:padding="34dp">

    <View
        android:layout_width="42dp"
        android:layout_height="3dp"
        android:background="@color/update_prompt_text_accent" />

    <TextView
        android:id="@+id/update_prompt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:textColor="@color/update_prompt_text_accent"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/update_prompt_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif-light"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/update_prompt_text_primary"
        android:textSize="34sp" />

    <TextView
        android:id="@+id/update_prompt_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif-light"
        android:lineSpacingExtra="5dp"
        android:textColor="@color/update_prompt_text_secondary"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/update_prompt_whats_new"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:textColor="@color/update_prompt_text_accent"
        android:textSize="12sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/update_prompt_notes_background"
        android:fadeScrollbars="false"
        android:maxHeight="228dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/update_prompt_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:lineSpacingExtra="6dp"
            android:padding="20dp"
            android:textColor="@color/update_prompt_text_primary"
            android:textSize="15sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/update_prompt_download"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/update_prompt_button_primary_background"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:textColor="@color/update_prompt_text_primary"
            android:textSize="15sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/update_prompt_later"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/update_prompt_button_secondary_background"
            android:fontFamily="sans-serif"
            android:textAllCaps="false"
            android:textColor="@color/update_prompt_text_primary"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>