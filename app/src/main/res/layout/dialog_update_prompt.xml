<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/update_prompt_panel_background"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/update_prompt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/opensans"
        android:textColor="@color/update_prompt_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/update_prompt_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/update_prompt_badge_background"
        android:fontFamily="@font/opensans"
        android:paddingLeft="14dp"
        android:paddingTop="8dp"
        android:paddingRight="14dp"
        android:paddingBottom="8dp"
        android:textColor="@color/update_prompt_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/update_prompt_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/opensans"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/update_prompt_text_secondary"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/update_prompt_whats_new"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/opensans"
        android:textColor="@color/update_prompt_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/update_prompt_notes_background"
        android:fadeScrollbars="false"
        android:maxHeight="240dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/update_prompt_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/opensans"
            android:lineSpacingExtra="4dp"
            android:padding="18dp"
            android:textColor="@color/update_prompt_text_primary"
            android:textSize="16sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/update_prompt_later"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:background="@drawable/update_prompt_button_secondary_background"
            android:fontFamily="@font/opensans"
            android:minWidth="164dp"
            android:textAllCaps="false"
            android:textColor="@color/update_prompt_text_primary"
            android:textSize="16sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/update_prompt_download"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginLeft="14dp"
            android:background="@drawable/update_prompt_button_primary_background"
            android:fontFamily="@font/opensans"
            android:minWidth="220dp"
            android:textAllCaps="false"
            android:textColor="@color/update_prompt_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>